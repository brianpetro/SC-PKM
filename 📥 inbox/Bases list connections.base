formulas:
  Connections: file.list_connections()
views:
  - type: table
    name: Table
    filters:
      and:
        - file.folder.startsWith("reference/PKM")
    order:
      - file.name
      - formula.Connections
    sort:
      - property: file.name
        direction: DESC
    limit: 10
    rowHeight: tall
    columnSize:
      file.name: 180
  - type: table
    name: New1
    limit: 10
